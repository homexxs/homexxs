{
  "name": "ConversationMessage",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "sender_email": {
      "type": "string"
    },
    "sender_name": {
      "type": "string"
    },
    "sender_role": {
      "type": "string",
      "enum": [
        "client",
        "admin",
        "staff_hr",
        "staff_operations"
      ],
      "default": "client"
    },
    "content": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "conversation_id",
    "sender_email"
  ]
}